# Optional provider tokens for cloning private HTTPS repos.
# Prefer read-only tokens.
# GitHub fine-grained PAT: Contents = Read-only for selected repositories.
# GitHub classic PATs use the broad repo scope for private repos.
GH_TOKEN=
GITLAB_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_TOKEN=

# Comma-separated repo list.
# Accepts GitHub owner/repo shorthand, full Git URLs, or local paths.
REPOS=owner/repo1,https://gitlab.com/group/repo2.git,https://bitbucket.org/workspace/repo3.git,/host/path/to/repo4

# Hours between scans
INTERVAL_HOURS=24

# Days of reports/ history to keep on disk. Older dated report files
# (.md, .findings.json, .state.json, .webhook.json) are deleted after each scan.
REPORT_RETENTION_DAYS=10

# Port the health dashboard web server listens on inside the container
WEB_PORT=8080

# Optional: protect the dashboard with HTTP Basic Auth.
# Leave both unset to leave the dashboard open (a warning is logged on startup).
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Optional: POST a JSON results payload here after each scan
WEBHOOK_URL=

# Optional LLM recommendations.
# Use "none", "ollama", or "openai-compatible".
LLM_PROVIDER=none
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=llama3.1
LLM_API_KEY=
